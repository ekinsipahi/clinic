#: clinic/templates/clinic/index-BAD.html:1342
#: clinic/templates/clinic/index.html:1371
msgid ""
"Bilimsel protokoller, kişiye özel dijital planlama ve steril süreçlerle; "
"yıllarca güvenle kullanabileceğiniz"
msgstr ""
"Mit wissenschaftlichen Protokollen, personalisierter digitaler Planung und "
"sterilen Prozessen; die Sie jahrelang sicher verwenden können"

#: clinic/templates/clinic/index-BAD.html:1343
#: clinic/templates/clinic/index.html:1372
msgid "kaliteli diş hekimliği"
msgstr "hochwertige Zahnmedizin"

#: clinic/templates/clinic/index-BAD.html:1349
#: clinic/templates/clinic/index.html:1378
