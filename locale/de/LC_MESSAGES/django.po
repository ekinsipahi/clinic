#: clinic/templates/clinic/index-BAD.html:1365
#: clinic/templates/clinic/index.html:1394
msgid "Yol Tarifi (Google Maps)"
msgstr "Wegbeschreibung (Google Maps)"

#: clinic/templates/clinic/index-BAD.html:1390
#: clinic/templates/clinic/index.html:1419
