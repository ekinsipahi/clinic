#: clinic/templates/clinic/index-BAD.html:487
#: clinic/templates/clinic/index.html:516
msgid "Ağrısız ve etkili kök kanal tedavileri."
msgstr "Schmerzfreie und effektive Wurzelkanalbehandlungen."

#: clinic/templates/clinic/index-BAD.html:491
#: clinic/templates/clinic/index-BAD.html:1777
#: clinic/templates/clinic/index.html:520
#: clinic/templates/clinic/index.html:2032
